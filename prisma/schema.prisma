// https://pris.ly/d/prisma-schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE")
  directUrl = env("DIRECT")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  USER
  ADMIN
}

enum ListingType {
  ITEM
  SKILL
}

enum ListingStatus {
  AVAILABLE
  SWAPPED
  SOLD
}

enum CategoryType {
  ITEM
  SKILL
}

enum TradeStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

enum AdminActionType {
  APPROVE
  REJECT
  EDIT
  DELETE
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ConversationStatus {
  OPEN
  CLOSED
}

//////////////////////////////////////////////////////
// USER & PROFILE
//////////////////////////////////////////////////////

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  emailDomain   String
  passwordHash  String
  isVerified    Boolean  @default(false)
  role          Role     @default(USER)
  createdAt     DateTime @default(now())

  allowedEmailDomain AllowedEmailDomain @relation(fields: [emailDomain], references: [domain], onDelete: Restrict)
  profile       Profile?

  listings      Listing[]
  interests     Interest[]
  messages      Message[]

  skillsOffered UserSkillOffered[]
  skillsNeeded  UserSkillNeeded[]

  tradesRequested Trade[] @relation("Requester")
  tradesOwned     Trade[] @relation("Owner")

  reports        Report[]
  adminActions   AdminAction[]
  conversations ConversationParticipant[]

  @@index([emailDomain])
}

model Profile {
  id        String  @id @default(uuid())
  userId    String  @unique
  fullName  String?
  bio       String?
  phone     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AllowedEmailDomain {
  id        String   @id @default(uuid())
  domain    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users User[]
}

//////////////////////////////////////////////////////
// SKILLS SYSTEM
//////////////////////////////////////////////////////

model Skill {
  id        String @id @default(uuid())
  name      String @unique

  offeredBy UserSkillOffered[]
  neededBy  UserSkillNeeded[]
}

model UserSkillOffered {
  id      String @id @default(uuid())
  userId  String
  skillId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

model UserSkillNeeded {
  id      String @id @default(uuid())
  userId  String
  skillId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

//////////////////////////////////////////////////////
// MARKETPLACE
//////////////////////////////////////////////////////

model Category {
  id    String       @id @default(uuid())
  name  String       @unique
  type  CategoryType

  listings Listing[]
}

model Listing {
  id          String        @id @default(uuid())
  userId      String
  title       String
  description String?
  categoryId  String
  listingType ListingType
  status      ListingStatus @default(AVAILABLE)
  moderationStatus ModerationStatus @default(PENDING)
  createdAt   DateTime      @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  Category @relation(fields: [categoryId], references: [id])

  images     ListingImage[]
  interests  Interest[]
  conversations Conversation[]
  trades     Trade[]
  reports    Report[]
  adminActions AdminAction[]

  @@index([categoryId])
  @@index([userId])
  @@index([status])
  @@index([listingType])
  @@index([createdAt])
  @@index([moderationStatus])
  @@index([categoryId, listingType, status, createdAt])
  @@unique([id, userId])
}

model ListingImage {
  id        String @id @default(uuid())
  listingId String
  imageUrl  String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////
// INTERACTIONS
//////////////////////////////////////////////////////

model Interest {
  id        String   @id @default(uuid())
  listingId String
  userId    String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId])
}

//////////////////////////////////////////////////////
// MESSAGING SYSTEM
//////////////////////////////////////////////////////

model Conversation {
  id        String   @id @default(uuid())
  listingId String
  status    ConversationStatus @default(OPEN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing      Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String @id @default(uuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
}

//////////////////////////////////////////////////////
// TRADE SYSTEM
//////////////////////////////////////////////////////

model Trade {
  id           String      @id @default(uuid())
  listingId    String
  requesterId  String
  ownerId      String
  status       TradeStatus @default(PENDING)
  createdAt    DateTime    @default(now())

  listing   Listing @relation(fields: [listingId, ownerId], references: [id, userId])
  requester User    @relation("Requester", fields: [requesterId], references: [id])
  owner     User    @relation("Owner", fields: [ownerId], references: [id])

  @@index([status])
  @@index([ownerId, status])
  @@index([requesterId, status])
  @@index([listingId, requesterId])
}

//////////////////////////////////////////////////////
// ADMIN FEATURES
//////////////////////////////////////////////////////

model Report {
  id         String   @id @default(uuid())
  listingId  String
  reportedBy String
  reason     String
  createdAt  DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id])
  user    User    @relation(fields: [reportedBy], references: [id])

  @@index([listingId])
  @@index([reportedBy])
}

model AdminAction {
  id         String           @id @default(uuid())
  adminId    String
  listingId  String
  actionType AdminActionType
  notes      String?
  createdAt  DateTime @default(now())

  admin   User    @relation(fields: [adminId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])

  @@index([adminId, createdAt])
  @@index([listingId, createdAt])
}